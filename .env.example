# ─── Firebase (Admin SDK, server-side) ───────────────────────
# Service account credentials. Crear en Firebase Console → Project Settings →
# Service accounts → "Generate new private key". Pegar acá el contenido del JSON
# en sus 3 campos: project_id, client_email, private_key.
FIREBASE_PROJECT_ID=recurrentes-app
[email protected]
# Importante: la private_key tiene \n literales que hay que respetar.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkq...\n-----END PRIVATE KEY-----\n"

# ─── Firebase Web SDK (client-side, prefijo VITE_) ───────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=recurrentes-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=recurrentes-app
VITE_FIREBASE_STORAGE_BUCKET=recurrentes-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Mercado Pago — credentials globales de la plataforma ────
# Estas son las credentials de la APP que registra Recurrentes en MP
# Developers — sirven para implementar OAuth para que cada comerciante
# conecte su propia cuenta MP. Si elegimos paste-token en lugar de OAuth,
# solo necesitamos las del front (Public Key) y cada merchant pega su
# Access Token desde el admin.
MP_APP_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=https://recurrentes-app.vercel.app/api/mp/oauth-callback

# ─── Shopify — App credentials ────────────────────────────────
# Crear app en partners.shopify.com → Apps → Create app → Public app
# Necesitamos OAuth para que cada merchant conecte su tienda.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_customers,write_orders,read_orders,write_draft_orders
SHOPIFY_REDIRECT_URI=https://recurrentes-app.vercel.app/api/shopify/oauth-callback

# ─── App ──────────────────────────────────────────────────────
APP_BASE_URL=https://recurrentes-app.vercel.app
# Secret para validar webhooks MP (opcional pero recomendado)
MP_WEBHOOK_SECRET=
